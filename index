<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mars.photo</title>
    <style>
        /* 1. 基础样式复位 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body, html {
            height: 100%;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: #000;
            color: #fff;
            overflow: hidden; /* 保持单页不滚动 */
        }

        /* 2. 背景设置 */
        .background {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            /* ❗ 这里已经修改为你的文件名 mars_bg.png ❗ */
            background: linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.5)), 
                        url('mars_bg.png');
            background-size: cover;
            background-position: center;
            z-index: 1;
        }

        /* 3. 极简内容居中 */
        .content {
            position: relative;
            z-index: 2;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 20px;
        }

        h1 {
            font-size: clamp(3rem, 10vw, 6rem);
            font-weight: 900;
            letter-spacing: -2px;
            margin-bottom: 0.5rem;
            text-transform: lowercase;
        }

        h1 span {
            color: #ff5722; /* 火星橙 */
        }

        p {
            font-size: 1.2rem;
            font-weight: 300;
            letter-spacing: 2px;
            opacity: 0.8;
            margin-bottom: 3rem;
        }

        /* 4. 磨砂质感按钮 */
        .cta {
            padding: 16px 45px;
            border: 1px solid rgba(255,255,255,0.3);
            background: rgba(255,255,255,0.1);
            color: white;
            text-decoration: none;
            border-radius: 50px;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            transition: all 0.3s ease;
            font-size: 0.9rem;
            letter-spacing: 2px;
        }

        .cta:hover {
            background: white;
            color: black;
            border-color: white;
            transform: translateY(-2px);
        }

        footer {
            position: absolute;
            bottom: 30px;
            z-index: 2;
            width: 100%;
            text-align: center;
            font-size: 0.7rem;
            opacity: 0.4;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

    <div class="background"></div>

    <div class="content">
        <h1>mars<span>.photo</span></h1>
        <p>EXPLORE THE RED PLANET</p>
        <a href="#" class="cta">ENTER ARCHIVE</a>
    </div>

    <footer>
        &copy; 2026 MARS.PHOTO | IMAGES STORED ON GITHUB
    </footer>

</body>
</html>
